{
  "name": "@tetherto/miningos-wrk-miner-antminer",
  "version": "1.0.0",
  "description": "MiningOS Worker Miner Antminer",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/miningos-wrk-miner-antminer.git"
  },
  "homepage": "https://github.com/tetherto/miningos-wrk-miner-antminer#readme",
  "bugs": {
    "url": "https://github.com/tetherto/miningos-wrk-miner-antminer/issues"
  },  
  "engines": {
    "node": ">=20"
  },
  "files": [
    "worker.js",
    "workers/",
    "mock/"
  ],
  "main": "worker.js",  
  "type": "commonjs",
  "bin": {
    "miningos-wrk-miner-antminer": "worker.js"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:integration": "NODE_ENV=test brittle ./tests/miner.test.js",
    "test:unit": "NODE_ENV=test brittle tests/unit/*.js",
    "test:coverage": "brittle --coverage tests/{,**/}*.test.js"
  },
  "dependencies": {
    "async": "3.2.6",
    "digest-fetch": "2.0.3",
    "miningos-tpl-wrk-miner": "git+https://github.com/tetherto/miningos-tpl-wrk-miner.git",
    "node-fetch": "2.7.0"
  },
  "devDependencies": {
    "@bitfinex/lib-js-util-base": "git+https://github.com/bitfinexcom/lib-js-util-base.git",
    "@bitfinex/lib-js-util-promise": "git+https://github.com/bitfinexcom/lib-js-util-promise.git",
    "@fastify/passport": "3.0.2",
    "@fastify/secure-session": "8.3.0",
    "brittle": "3.16.3",
    "debug": "4.4.1",
    "miningos-mock-control-service": "git+https://github.com/tetherto/miningos-mock-control-service.git",
    "passport-http": "0.3.0",
    "standard": "17.1.2",
    "yargs": "17.7.2"
  }
}
